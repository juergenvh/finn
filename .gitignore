# --- node ---
node_modules/
.svelte-kit/
build/
dist/

# --- SvelteKit / Vite output ---
.output/
.vercel/
.netlify/
.wrangler/
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# --- env ---
.env
.env.*
!.env.example
!.env.test

# --- editor / OS ---
.DS_Store
Thumbs.db
.idea/
*.swp

# --- finn-specific ---
# The data volume lives at ~/finn-data on the host, mounted into the
# container at /data. Database, secrets, and exports must never live
# inside the repo. These patterns catch accidents.
**/*.db
**/*.db-shm
**/*.db-wal
**/secrets/
**/secrets.json
**/api-keys*
**/*token*
**/credentials*
**/exports/

# --- runtime / logs ---
*.log
.pnpm-debug.log*
.npm-debug.log*
.yarn-debug.log*
.yarn-error.log*
