# --- node ---
node_modules/
.svelte-kit/
build/
dist/
.env
.env.*
!.env.example

# --- editor / OS ---
.DS_Store
.idea/
.vscode/
*.swp

# --- finn-specific ---
# The data volume lives at ~/finn-data on the host, mounted into the
# container at /data. Database, secrets, and exports must never live
# inside the repo. These patterns catch accidents.
**/*.db
**/*.db-shm
**/*.db-wal
**/secrets/
**/secrets.json
**/api-keys*
**/*token*
**/credentials*
**/exports/

# --- runtime / logs ---
*.log
.pnpm-debug.log*
.npm-debug.log*
.yarn-debug.log*
.yarn-error.log*
