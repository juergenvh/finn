{
	// Compiles only the standalone server-side modules that live next to the
	// SvelteKit app but are NOT imported by Svelte/Kit itself: the WS
	// attach-helper, the connector layer, and the production server entry.
	//
	// SvelteKit's own server build (adapter-node) bundles the route code
	// into build/. This config produces a parallel dist-server/ tree that
	// `server.js` consumes at runtime.
	//
	// Why not let adapter-node bundle these too? Because adapter-node only
	// compiles modules that are reachable from a route or hook. The WS
	// server is intentionally outside that graph (it lives next to the
	// SvelteKit handler, not inside it), so it needs its own compilation.
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"rewriteRelativeImportExtensions": true,
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"declaration": false,
		"sourceMap": true,
		"outDir": "dist-server",
		"rootDir": "src/lib/server"
	},
	"include": [
		"src/lib/server/**/*.ts"
	],
	"exclude": [
		"node_modules",
		".svelte-kit",
		"build"
	]
}
